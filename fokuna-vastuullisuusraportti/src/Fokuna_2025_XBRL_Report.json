   }
  },
  "f61": {
   "value": "The reporting period covers 6 October 2025 to 31 December 2025. The undertaking commenced its operations during this period. No turnover was generated during the reporting period. Consequently, greenhouse gas emission intensity per turnover is not considered a meaningful performance indicator for this reporting period. Financial figures are based on the accounting information available at the reporting date. The final year-end financial statements had not yet been prepared at the time of reporting.",
   "dimensions": {
    "concept": "vsme:DisclosureOfAnyOtherGeneralAndOrEntitySpecificInformation",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f62": {
   "value": "During the reporting period, total electricity consumption amounted to 0.04951 MWh (49.51 kWh). Scope 2 greenhouse gas emissions (location-based) were calculated using the average emission factor for electricity generation in Finland (26 gCO\u2082/kWh). Based on this methodology, Scope 2 emissions amount to 0.001287 tCO\u2082e. Values in the report are presented with two decimal precision; therefore, Scope 2 emissions are displayed as 0.00 tCO\u2082e, although the unrounded value is included in the total emissions calculation.",
   "dimensions": {
    "concept": "vsme:DisclosureOfAnyOtherEnvironmentalAndOrEntitySpecificEnvironmentalDisclosures",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f63": {
   "value": "The undertaking had no employees during the reporting period and therefore no additional social disclosures are applicable.",
   "dimensions": {
    "concept": "vsme:DisclosureOfAnyOtherSocialAndOrEntitySpecificSocialDisclosures",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f64": {
   "value": "The undertaking is a sole proprietorship and does not have a separate governance body. Governance responsibilities rest with the entrepreneur.",
