  "f49": {
   "value": "The undertaking provides sustainability reporting advisory services, including VSME reporting solutions, as well as the development of data-driven management practices and Power BI dashboards for SMEs.",
   "dimensions": {
    "concept": "vsme:DescriptionOfSignificantGroupsOfProductsAndOrServicesOffered",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f50": {
   "value": "The primary market consists of Finnish small and medium-sized enterprises (SMEs), particularly within professional and service-oriented sectors. The undertaking operates on a business-to-business (B2B) basis.",
   "dimensions": {
    "concept": "vsme:DescriptionOfSignificantMarketsTheUndertakingOperatesIn",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f51": {
   "value": "The undertaking\u2019s clients are small and medium-sized enterprises (SMEs). Operations are based on direct client relationships without intermediaries. Key suppliers relate to standard digital tools and software services used in the provision of advisory services.",
   "dimensions": {
    "concept": "vsme:DescriptionOfMainBusinessRelationships",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f52": {
   "value": "Sustainability considerations are integrated into the undertaking\u2019s business model. The services support clients in their transition towards more sustainable operations. Activities are primarily digital and resource-light, and sustainability-related information is used in the ongoing development of services.",
   "dimensions": {
    "concept": "vsme:DescriptionOfKeyElementsOfStrategyThatRelatesToOrAffectsSustainabilityIssues",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f53": {
   "value": "Sustainability is integrated into Fokuna\u2019s business model. Operations are based on a digital and resource-light approach. During the reporting period, monitoring of energy consumption was initiated and preparations were made to establish a systematic recording of business travel. In equipment procurement, used or long-life solutions are preferred where feasible. Responsibility for sustainability-related practices and their development lies with the entrepreneur.",
   "dimensions": {
    "concept": "vsme:DescriptionOfPracticesPoliciesAndOrFutureInitiatives",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f54": {
   "value": "Miska-Matias Kettunen",
   "dimensions": {
    "concept": "vsme:MostSeniorLevelAccountableForImplementationOfPolicies",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
  "f55": {
   "value": "No separate quantitative targets were established during the reporting period. The undertaking\u2019s objective is to progressively develop a more systematic approach to monitoring sustainability-related information as operations grow, taking into account the principle of proportionality.",
   "dimensions": {
    "concept": "vsme:DescriptionOfATargetRelatedToAPolicy",
    "entity": "scheme:FI3569982",
    "period": "2025-10-06T00:00:00/2026-01-01T00:00:00"
   }
  },
